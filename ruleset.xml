<?xml version="1.0"?>
<ruleset name="apex-tracked-record"
	xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

	<description>
		Curated Apex ruleset for apex-tracked-record. Focuses on rules that catch
		real bugs and security issues. Drops opinionated style rules (Prettier
		handles formatting) and overly aggressive complexity rules that fire on
		legitimately complex domain logic.

		See ruleset.xml in the repo root for rationale on individual rule choices.
	</description>

	<!-- ── Best Practices ──────────────────────────────────────── -->

	<rule ref="category/apex/bestpractices.xml/UnusedLocalVariable" />
	<rule ref="category/apex/bestpractices.xml/AvoidGlobalModifier" />
	<!--
		Dropped: ApexUnitTestClassShouldHaveAsserts (false positives on tests
		using try/catch verification). Suppress per test class with
		@SuppressWarnings('PMD.ApexUnitTestClassShouldHaveAsserts').
	-->

	<!-- ── Error Prone ─────────────────────────────────────────── -->

	<rule ref="category/apex/errorprone.xml/AvoidHardcodingId" />
	<rule ref="category/apex/errorprone.xml/AvoidDirectAccessTriggerMap" />
	<rule ref="category/apex/errorprone.xml/EmptyCatchBlock" />
	<rule ref="category/apex/errorprone.xml/EmptyIfStmt" />
	<rule ref="category/apex/errorprone.xml/EmptyWhileStmt" />
	<rule ref="category/apex/errorprone.xml/EmptyStatementBlock" />
	<rule ref="category/apex/errorprone.xml/EmptyTryOrFinallyBlock" />

	<!-- ── Performance ─────────────────────────────────────────── -->

	<rule ref="category/apex/performance.xml/AvoidDmlStatementsInLoops" />
	<rule ref="category/apex/performance.xml/AvoidSoqlInLoops" />
	<rule ref="category/apex/performance.xml/AvoidDebugStatements" />
	<rule ref="category/apex/performance.xml/OperationWithLimitsInLoop" />

	<!-- ── Security ────────────────────────────────────────────── -->

	<rule ref="category/apex/security.xml/ApexCRUDViolation" />
	<rule ref="category/apex/security.xml/ApexInsecureEndpoint" />
	<rule ref="category/apex/security.xml/ApexOpenRedirect" />
	<rule ref="category/apex/security.xml/ApexSOQLInjection" />
	<rule ref="category/apex/security.xml/ApexSharingViolations" />
	<rule ref="category/apex/security.xml/ApexBadCrypto" />
	<rule ref="category/apex/security.xml/ApexCSRF" />

	<!-- ── Design (only ExcessiveParameterList, with bumped threshold) ── -->

	<rule ref="category/apex/design.xml/ExcessiveParameterList">
		<properties>
			<!-- Default is 4. Bumped to 6 because real Apex constructors
			     and complex builders frequently have 5-6 parameters legitimately. -->
			<property name="minimum" value="6" />
		</properties>
	</rule>

	<!--
		Explicitly excluded — see CONTRIBUTING.md for rationale:

		category/apex/codestyle.xml — entire category
		  Prettier handles formatting decisions. Brace rules in particular
		  prevent legitimate single-line guard clauses (if (cond) return;).

		category/apex/design.xml/CyclomaticComplexity
		category/apex/design.xml/CognitiveComplexity
		category/apex/design.xml/NPathComplexity
		category/apex/design.xml/StdCyclomaticComplexity
		category/apex/design.xml/NcssCount
		category/apex/design.xml/ExcessiveClassLength
		  Default thresholds fire on legitimately complex domain logic.
		  Code review catches actually-too-complex methods.

		category/apex/documentation.xml/ApexDoc
		  Subjective; project policy is ApexDoc on public + meaningful
		  private methods, not blanket coverage.
	-->
</ruleset>
